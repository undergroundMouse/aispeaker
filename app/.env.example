# Backend control plane (production path)
VITE_BACKEND_BASE_URL=http://localhost:3000
VITE_DEVICE_API_TOKEN=dev-device-token
VITE_ADMIN_API_TOKEN=dev-admin-token
# server = backend authority, shadow = client budget + backend telemetry, client = direct Qwen if key set
VITE_CLOUD_AUTHORITY_MODE=server

# Legacy direct Qwen path (development only when backend is disabled)
VITE_QWEN_API_KEY=
VITE_QWEN_BASE_URL=https://llm.wavespeed.ai/v1
VITE_QWEN_MODEL=qwen/qwen3-vl-8b-thinking

PORT=3000
DEVICE_API_TOKEN=dev-device-token
ADMIN_API_TOKEN=dev-admin-token
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
DATABASE_PATH=./data/control-plane.json

# Cloud vision-language model (OpenAI-compatible Chat Completions)
# Keys stay on the server only — never put them in app/.env.local

# --- 国内推荐：阿里云百炼 DashScope ---
# API Key: https://help.aliyun.com/zh/model-studio/get-api-key
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-vl-plus

# --- 海外备选：WaveSpeed ---
# QWEN_API_KEY=
# QWEN_BASE_URL=https://llm.wavespeed.ai/v1
# QWEN_MODEL=qwen/qwen3-vl-8b-thinking

# Qwen-Omni Realtime (hybrid dialogue primary transport)
# Requires DashScope Omni Realtime access on your API key.
# Domestic WebSocket endpoint (default):
QWEN_OMNI_REALTIME_MODEL=qwen3.5-omni-plus-realtime
QWEN_OMNI_REALTIME_BASE_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
# International endpoint alternative:
# QWEN_OMNI_REALTIME_BASE_URL=wss://dashscope-intl.aliyuncs.com/api-ws/v1/realtime
QWEN_OMNI_VOICE=Cherry
QWEN_OMNI_TURN_DETECTION=server_vad
QWEN_OMNI_SILENCE_DURATION_MS=500

# Backend control plane (production path)
VITE_BACKEND_BASE_URL=http://localhost:3000
VITE_DEVICE_API_TOKEN=dev-device-token
VITE_ADMIN_API_TOKEN=dev-admin-token
# server = backend authority, shadow = client budget + backend telemetry, client = direct Qwen if key set
VITE_CLOUD_AUTHORITY_MODE=server

# Realtime session flags (legacy stitched pipeline)
# VITE_REALTIME_SESSION_MODE=true
# VITE_FULL_DUPLEX_ENABLED=true
# VITE_VISION_LEVEL3_ENABLED=true

# Hybrid Qwen-Omni Realtime dialogue (default: enabled; set false to disable at build time)
# VITE_HYBRID_OMNI_DIALOGUE=false
# VITE_VISION_LEVEL3_ENABLED=false
# VITE_OMNI_VL_CORRECTION_MODE=ui-only

# Legacy direct Qwen path (development only when backend is disabled)
VITE_QWEN_API_KEY=
VITE_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VITE_QWEN_MODEL=qwen-vl-plus
